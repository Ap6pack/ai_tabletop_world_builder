# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# LLM Provider Configuration
# Set your preferred default provider: openai, anthropic, together, or ollama
DEFAULT_LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TEMPERATURE=0.7

# Together AI Configuration
TOGETHER_API_KEY=your_together_api_key_here
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
TOGETHER_TEMPERATURE=0.7

# Ollama Configuration (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.7

# Content Policy
# Options: defensive, educational, advanced, unrestricted
DEFAULT_CONTENT_POLICY=educational

# Session Configuration
SESSION_TIMEOUT=3600
MAX_CONTEXT_LENGTH=4000

# Authentication
# When REQUIRE_AUTH=false (default), the API is open — convenient for local dev.
# When REQUIRE_AUTH=true, product endpoints require a valid bearer token and
# admin operations (clearing data, config writes) require the admin role; you
# MUST also set a strong JWT_SECRET_KEY or the app refuses to start.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
REQUIRE_AUTH=false
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins; empty allows the local Streamlit default)
CORS_ORIGINS=

# Rate limiting (per authenticated user, or per client IP when anonymous).
# Protects LLM-backed endpoints from abuse. Uses Redis when REDIS_URL is set.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Storage
SCENARIOS_PATH=./scenarios/generated
DATA_PATH=./data

# Database (SQLAlchemy URL) for mutable state: users, game sessions, exercises,
# API keys, and webhooks. Defaults to a local SQLite file. For production use a
# managed Postgres database, e.g.:
#   DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
# (Postgres requires the psycopg driver: pip install "psycopg[binary]")
DATABASE_URL=sqlite:///./data/app.db

# Optional: Redis URL to use as a low-latency fast-path for live multi-team
# exercises. Leave empty to use the database for exercise state as well.
# REDIS_URL=redis://localhost:6379/0
