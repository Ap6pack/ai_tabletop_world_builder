# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# LLM Provider Configuration
# Set your preferred default provider: openai, anthropic, together, or ollama
DEFAULT_LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TEMPERATURE=0.7

# Together AI Configuration
TOGETHER_API_KEY=your_together_api_key_here
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
TOGETHER_TEMPERATURE=0.7

# Ollama Configuration (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.7

# Content Policy
# Options: defensive, educational, advanced, unrestricted
DEFAULT_CONTENT_POLICY=educational

# Session Configuration
SESSION_TIMEOUT=3600
MAX_CONTEXT_LENGTH=4000

# Authentication
# Auth is opt-in and currently development-grade: when REQUIRE_AUTH=false the
# API endpoints are NOT protected. If you set REQUIRE_AUTH=true you MUST also
# set a strong JWT_SECRET_KEY (the app refuses to start with the placeholder).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
REQUIRE_AUTH=false
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins; empty allows the local Streamlit default)
CORS_ORIGINS=

# Storage
SCENARIOS_PATH=./scenarios/generated
DATA_PATH=./data
